#!/bin/bash
# Pre-commit hook: runs linting on staged Python files

set -e

# Get repo root (works whether run from hooks/ or .git/hooks/)
ROOT_DIR="$(git rev-parse --show-toplevel)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

# Get staged Python files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
    exit 0
fi

echo "Running pre-commit checks..."

# Activate venv
if [ -f "$ROOT_DIR/server/venv/bin/activate" ]; then
    source "$ROOT_DIR/server/venv/bin/activate"
else
    echo -e "${RED}Error: venv not found. Run ./setup.sh first.${NC}"
    exit 1
fi

# Run ruff check
echo "Checking with ruff..."
if ! ruff check $STAGED_PY; then
    echo -e "${RED}Ruff check failed. Fix issues or run 'ruff check --fix' to auto-fix.${NC}"
    exit 1
fi

# Run ruff format check
echo "Checking formatting..."
if ! ruff format --check $STAGED_PY 2>/dev/null; then
    echo -e "${RED}Formatting issues found. Run 'ruff format' to fix.${NC}"
    exit 1
fi

echo -e "${GREEN}Pre-commit checks passed.${NC}"
