---
# Copy this file to secrets.yaml and fill in your actual keys
# Then run: kubectl apply -f k8s/secrets.yaml
#
# IMPORTANT: secrets.yaml is gitignored - never commit it!
#
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
type: Opaque
stringData:
  # Required: Your Anthropic API key (or dummy key when using mock)
  ANTHROPIC_API_KEY: "sk-ant-api03-YOUR-KEY-HERE"
  
  # Required: Braintrust API key for prompt fetching
  BRAINTRUST_API_KEY: "sk-YOUR-BRAINTRUST-KEY-HERE"