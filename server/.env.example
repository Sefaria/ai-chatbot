# Django Settings
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DJANGO_DEBUG=True

# Anthropic API (Required)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=<your-anthropic-api-key-here>

BRAINTRUST_API_KEY=<your-braintrust-api-key-here>
BRAINTRUST_PROJECT=<your-braintrust-project-name-here>

CORE_PROMPT_SLUG=core-8fbc


DB_NAME=<your-db-name-here>
DB_USER=<your-db-user-here>
DB_PASSWORD=<your-db-password-here>
DB_HOST=<your-db-host-here>
DB_PORT=<your-db-port-here>

CHATBOT_USER_TOKEN_SECRET=<your-chatbot-user-token-secret-here>
