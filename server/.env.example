# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True

# Database Configuration
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# Anthropic API (Required)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LangSmith Tracing (Optional)
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=sefaria-chatbot
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Langfuse Tracing (Optional)
# Get your keys from: https://cloud.langfuse.com/ (or self-hosted instance)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
# For US region, use: https://us.cloud.langfuse.com

# Braintrust Configuration (Optional - for remote prompt management)
# Get your API key from: https://www.braintrust.dev/
# BRAINTRUST_API_KEY=your_braintrust_api_key
# BRAINTRUST_PROJECT=On Site Agent
# BRAINTRUST_LOGGING_ENABLED=true  # Set to false to disable tracing (useful for load tests)

# AI Router & Guardrails Configuration
# Enable/disable AI-based classification (default: true)
ROUTER_USE_AI=true
GUARDRAILS_USE_AI=true

# Model selection — override defaults from settings.py
# AGENT_MODEL=claude-sonnet-4-5-20250929
# GUARDRAIL_MODEL=claude-haiku-4-5-20251001
# SUMMARY_MODEL=claude-haiku-4-5-20251001

# Sefaria API Configuration (Optional - defaults to public API)
# SEFARIA_API_BASE_URL=https://www.sefaria.org
# SEFARIA_AI_BASE_URL=https://ai.sefaria.org
# SEFARIA_AI_TOKEN=your-sefaria-ai-token-if-needed

# Environment
ENVIRONMENT=dev
