WEBLATE_SITE_DOMAIN=weblate.sefaria.org
WEBLATE_SITE_TITLE=Sefaria Translations
WEBLATE_ADMIN_EMAIL=dev@sefaria.org
WEBLATE_ADMIN_NAME=Admin
WEBLATE_ADMIN_PASSWORD=
WEBLATE_SECRET_KEY=
WEBLATE_ALLOWED_HOSTS=weblate.sefaria.org

POSTGRES_PASSWORD=
REDIS_PASSWORD=

WEBLATE_REGISTRATION_OPEN=0
WEBLATE_REGISTRATION_ALLOW_BACKENDS=google-oauth2
WEBLATE_REQUIRE_LOGIN=1
WEBLATE_AUTH_LOCK_DEFAULT=1
WEBLATE_NO_EMAIL_AUTH=1
WEBLATE_SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
WEBLATE_SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
WEBLATE_SOCIAL_AUTH_GOOGLE_OAUTH2_WHITELISTED_DOMAINS=sefaria.org

WEBLATE_GITHUB_USERNAME=
WEBLATE_GITHUB_TOKEN=
WEBLATE_GITHUB_WEBHOOK_SECRET=

WEBLATE_ENABLE_HTTPS=1
WEBLATE_IP_PROXY_HEADER=HTTP_X_FORWARDED_FOR
WEBLATE_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
